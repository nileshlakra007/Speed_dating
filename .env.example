# Storage backend — set ONE of these (neither is needed for local dev,
# which falls back to an in-memory store).

# Neon Postgres (recommended). On Vercel this is injected automatically
# when you add the Neon integration. Use the POOLED connection string.
# DATABASE_URL=postgres://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Upstash Redis (alternative)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Google Sign-In (hosts + attendees). Create an OAuth 2.0 Client ID of type
# "Web application" at https://console.cloud.google.com/apis/credentials,
# add your domains (http://localhost:3000 and your Vercel URL) under
# "Authorized JavaScript origins", and paste the client id here. This value
# is public by design — no client secret is needed for this flow.
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
